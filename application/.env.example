# ===== Supabase =====
# Project URL — Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Anon key — Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key — Settings → API → service_role secret
# (server-only; never expose to browser; only used by drizzle/seed.ts)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ===== Database =====
# Option A: Managed Supabase (recommended for dev — free tier)
# Drizzle connection string. Get from Supabase → Settings → Database → Connection string.
# Use the "Session pooler" (port 6543) for runtime; "Direct" (port 5432) for migrations.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres

# Option B: Local Docker Postgres (run `docker compose up -d` first)
# Uncomment these and comment out the Supabase ones above.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/competency
# DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:5432/competency

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Dev toggles =====
# Set to "true" to use mock data layer (src/lib/mock-data/) instead of real DB.
# Useful before Supabase is set up. Default: false.
NEXT_PUBLIC_USE_MOCK=false
