# ===== Supabase =====
# Project URL — Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Anon key — Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key — Settings → API → service_role secret
# (server-only; never expose to browser; only used by drizzle/seed.ts)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ===== Database =====
# Option A: Managed Supabase (recommended for dev — free tier)
# Drizzle connection string. Get from Supabase → Settings → Database → Connection string.
# Use the "Session pooler" (port 6543) for runtime; "Direct" (port 5432) for migrations.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres

# Option B: Local Docker Postgres
#   - Fresh container via `docker compose up -d` (host port 5433, user/pass postgres/postgres)
#     DATABASE_URL=postgresql://postgres:postgres@localhost:5433/competency
#   - Or reuse an existing Postgres container — create DB first:
#     docker exec <container> psql -U postgres -c "CREATE DATABASE competency;"
#     docker exec <container> psql -U postgres -d competency -c 'CREATE EXTENSION IF NOT EXISTS "pgcrypto";'
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/competency
# DATABASE_URL_DIRECT=postgresql://postgres:YOUR_PASSWORD@localhost:5432/competency

# ===== App =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# No mock-data runtime toggle. App reads from real backend/API routes only.
