  "tracks": [
    {
      "levelCode": "XS",
      "title": "Foundational Track",
      "description": "Build your DevOps base — AWS, Terraform fundamentals, Go basics.",
      "weeks": [
        {
          "index": 1,
          "title": "Setup, AWS Foundations, IAM Deep Dive",
          "summary": "Tuần 1 — môi trường dev, AWS account hygiene, IAM cơ bản đến nâng cao.",
          "goals": [
            "Thiết lập AWS Org + 3 accounts + Budget Alarm",
            "Hiểu IAM evaluation logic (deny > allow > implicit deny)",
            "Phân biệt SCP / Permission Boundary / IAM Policy / Session Policy"
          ],
          "keywords": ["IAM","SCP","Permission Boundary","MFA","SSO","STS"],
          "estHours": 8,
          "modules": [
            {
              "title": "AWS Account Hygiene",
              "summary": "Setup AWS Organizations, Identity Center, MFA, Budget Alarm — không dùng root, không tạo IAM User.",
              "lessons": [
                {
                  "slug": "iam-identity-center",
                  "title": "IAM Identity Center & MFA",
                  "introMd": "**IAM Identity Center** (trước đây là AWS SSO) là cách quản lý user tập trung của AWS 2026. Trong lesson này bạn sẽ học vì sao **không bao giờ** nên tạo IAM Users cho dev, và cách dùng SSO + permission sets.",
                  "estMinutes": 7,
                  "skillsAdvanced": [
                    { "skillSlug": "iam-deep", "contributesToLevel": "XS", "weight": 1 }
                  ],
                  "exercises": [
                    {
                      "kind": "mcq",
                      "promptMd": "Đâu là cách quản lý dev access AWS **khuyến nghị 2026**?",
                      "payload": {
                        "options": [
                          { "id": "a", "text": "Tạo IAM User + Access Key cho mỗi dev" },
                          { "id": "b", "text": "IAM Identity Center + SSO + temporary credentials" },
                          { "id": "c", "text": "Share root account credentials" },
                          { "id": "d", "text": "Tạo 1 IAM User chung cho cả team" }
                        ],
                        "correctId": "b",
                        "shuffle": true
                      },
                      "explanationMd": "IAM Identity Center cấp credentials **tạm thời** (1-12h) qua SSO, không có long-lived access key bị rò rỉ. Đây là chuẩn 2026.",
                      "xpAward": 10
                    },
                    {
                      "kind": "mcq_multi",
                      "promptMd": "Thứ tự đánh giá IAM policy nào ĐÚNG? (chọn tất cả áp dụng)",
                      "payload": {
                        "options": [
                          { "id": "a", "text": "Explicit deny > Explicit allow" },
                          { "id": "b", "text": "Implicit allow > Explicit deny" },
                          { "id": "c", "text": "Explicit allow > Implicit deny" },
                          { "id": "d", "text": "SCP > IAM Policy > Permission Boundary" }
                        ],
                        "correctIds": ["a", "c"],
                        "shuffle": false
                      },
                      "explanationMd": "Quy tắc: **explicit deny > explicit allow > implicit deny**. SCP/Permission Boundary đều có thể chặn (intersection of all permissions).",
                      "xpAward": 10
                    },
                    {
                      "kind": "fill_blank",
                      "promptMd": "Hoàn thành câu: 'Khi user assume role, credentials trả về có thời hạn tối đa ___ giờ (mặc định 1, tối đa cấu hình được lên 12).'",
                      "payload": {
                        "template": "Credentials assume role có thời hạn tối đa ___ giờ.",
                        "blanks": [
                          { "id": 1, "accepts": ["12", "twelve"], "matchKind": "exact_ci" }
                        ]
                      },
                      "explanationMd": "STS `AssumeRole` có max session duration 12 giờ (configurable trên role).",
                      "xpAward": 10
                    }
                  ]
                },
                {
                  "slug": "iam-policy-eval",
                  "title": "IAM Policy Evaluation Logic",
                  "introMd": "Hiểu cách AWS đánh giá quyền: SCP → Permission Boundary → IAM Policy → Session Policy. Tất cả 4 lớp phải đồng ý → request được allow.",
                  "estMinutes": 8,
                  "skillsAdvanced": [
                    { "skillSlug": "iam-deep", "contributesToLevel": "XS", "weight": 1 }
                  ],
                  "exercises": [
                    {
                      "kind": "order_steps",
                      "promptMd": "Sắp xếp 4 layer permission AWS đánh giá theo thứ tự (top-down, từ org đến session):",
                      "payload": {
                        "steps": [
                          { "id": "1", "text": "Service Control Policy (SCP) — org level" },
                          { "id": "2", "text": "Permission Boundary — account level" },
                          { "id": "3", "text": "IAM Policy (identity-based + resource-based)" },
                          { "id": "4", "text": "Session Policy — STS request" }
                        ],
                        "correctOrder": ["1", "2", "3", "4"]
                      },
                      "explanationMd": "Tất cả 4 layer phải đồng ý → action được allow. 1 explicit deny ở bất kỳ layer = deny.",
                      "xpAward": 10
                    },
                    {
                      "kind": "type_answer",
                      "promptMd": "Lệnh AWS CLI nào in ra danh tính hiện tại (account, user/role, ARN)?",
                      "payload": {
                        "accepts": ["^aws\\s+sts\\s+get-caller-identity$"],
                        "matchKind": "regex",
                        "hint": "aws sts ..."
                      },
                      "explanationMd": "`aws sts get-caller-identity` là lệnh debug đầu tiên khi cấu hình credentials.",
                      "xpAward": 10
                    },
                    {
                      "kind": "code_block_review",
                      "promptMd": "Vấn đề bảo mật của IAM policy sau là gì?",
                      "payload": {
                        "code": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"*\",\n      \"Resource\": \"*\"\n    }\n  ]\n}",
                        "language": "json",
                        "question": "Lỗi gì?",
                        "options": [
                          { "id": "a", "text": "Thiếu Version" },
                          { "id": "b", "text": "Over-privileged: cho phép mọi action trên mọi resource" },
                          { "id": "c", "text": "Sai cú pháp JSON" },
                          { "id": "d", "text": "Thiếu Condition" }
                        ],
                        "correctId": "b"
                      },
                      "explanationMd": "Policy `Action: *` + `Resource: *` = admin god mode. Vi phạm least-privilege. Cần liệt kê action cụ thể + resource cụ thể.",
                      "xpAward": 15
                    }
                  ]
                }
              ]
            }
          ]
        },

        { "index": 2, "title": "Terraform Foundation + State + Provider", "summary": "HCL2, providers, S3+DynamoDB backend, state surgery.", "goals": ["Hiểu terraform plan flow", "Setup remote state"], "keywords": ["HCL","state","backend"], "estHours": 8, "modules": [] },
